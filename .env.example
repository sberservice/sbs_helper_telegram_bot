TELEGRAM_TOKEN=your_bot_token_here
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=sprint_db
MYSQL_PORT=3306
DEBUG=0

# Telegram API network settings
# Профиль 1 (умеренно медленная сеть) — активный по умолчанию:
TELEGRAM_HTTP_MAX_RETRIES=4
TELEGRAM_HTTP_RETRY_BACKOFF_SECONDS=2
# Таймаут установки TCP/TLS-соединения для sendMessage (сек.)
TELEGRAM_SEND_MSG_CONNECT_TIMEOUT_SECONDS=5
# Таймаут ожидания ответа Telegram после отправки sendMessage (сек.)
TELEGRAM_SEND_MSG_READ_TIMEOUT_SECONDS=30
# Таймаут установки TCP/TLS-соединения для sendDocument (сек.)
TELEGRAM_SEND_DOC_CONNECT_TIMEOUT_SECONDS=20
# Таймаут чтения ответа Telegram при загрузке файла sendDocument (сек.)
TELEGRAM_SEND_DOC_READ_TIMEOUT_SECONDS=300

# Профиль 2 (очень медленная/нестабильная сеть) — раскомментируйте при необходимости:
# TELEGRAM_HTTP_MAX_RETRIES=6
# TELEGRAM_HTTP_RETRY_BACKOFF_SECONDS=2
# Таймаут установки TCP/TLS-соединения для sendMessage (сек.)
# TELEGRAM_SEND_MSG_CONNECT_TIMEOUT_SECONDS=10
# Таймаут ожидания ответа Telegram после отправки sendMessage (сек.)
# TELEGRAM_SEND_MSG_READ_TIMEOUT_SECONDS=60
# Таймаут установки TCP/TLS-соединения для sendDocument (сек.)
# TELEGRAM_SEND_DOC_CONNECT_TIMEOUT_SECONDS=30
# Таймаут чтения ответа Telegram при загрузке файла sendDocument (сек.)
# TELEGRAM_SEND_DOC_READ_TIMEOUT_SECONDS=600

# Telethon (for chat members sync)
# Get API credentials from https://my.telegram.org
TELETHON_API_ID=12345678
TELETHON_API_HASH=your_api_hash_here

# Chat members sync configuration
SYNC_CHAT_ID=-1001395495746
SYNC_INTERVAL_HOURS=6
TELETHON_SESSION_NAME=chat_sync_session

# FIAS address validation (DaData)
# Get your API key at https://dadata.ru/profile/
DADATA_API_KEY=your_dadata_api_key_here
# Optional: override the API base URL
# DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs
# Optional: choose the FIAS provider (default: dadata)
# FIAS_PROVIDER=dadata

# =============================================
# AI / RAG (опционально)
# =============================================
# AI_RAG_ENABLED=1
# AI_RAG_CHUNK_SIZE=1000
# AI_RAG_CHUNK_OVERLAP=150
# AI_RAG_TOP_K=8
# AI_RAG_MAX_CONTEXT_CHARS=14000
# AI_RAG_SUMMARY_ENABLED=1
# AI_RAG_PREFILTER_TOP_DOCS=12
# AI_RAG_PROMPT_SUMMARY_DOCS=3

# Векторный retrieval (локальный)
# AI_RAG_VECTOR_ENABLED=0
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_TOP_K=12
# AI_RAG_VECTOR_PREFETCH_K=40
# AI_RAG_VECTOR_EMBEDDING_MODEL=BAAI/bge-m3
# AI_RAG_VECTOR_DEVICE=auto
# AI_RAG_VECTOR_EMBEDDING_FP16=0
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=8
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=6000
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.45
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.55

# =============================================
# Профили vector RAG (готовые пресеты)
# =============================================

# Профиль A: macOS (сбалансированный, BGE-M3)
# AI_RAG_VECTOR_ENABLED=1
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_EMBEDDING_MODEL=BAAI/bge-m3
# AI_RAG_VECTOR_EMBEDDING_FP16=0
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=6
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=5000
# AI_RAG_VECTOR_TOP_K=14
# AI_RAG_VECTOR_PREFETCH_K=42
# AI_RAG_TOP_K=8
# AI_RAG_MAX_CONTEXT_CHARS=14000
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.40
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.60

# Профиль B: Windows (i5-3550 + NVIDIA T400, стабильный)
# Рекомендация: использовать более лёгкую multilingual модель.
# AI_RAG_VECTOR_ENABLED=1
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# AI_RAG_VECTOR_DEVICE=auto
# AI_RAG_VECTOR_EMBEDDING_FP16=1
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=2
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=3500
# AI_RAG_VECTOR_TOP_K=10
# AI_RAG_VECTOR_PREFETCH_K=24
# AI_RAG_TOP_K=7
# AI_RAG_MAX_CONTEXT_CHARS=12000
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.55
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.45