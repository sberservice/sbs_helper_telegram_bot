# =============================================
# Telegram Bot
# =============================================
TELEGRAM_TOKEN=your_bot_token_here

# =============================================
# Database (MySQL)
# =============================================
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=sprint_db
MYSQL_PORT=3306

# =============================================
# General
# =============================================
DEBUG=0

# =============================================
# Admin Web authentication
# =============================================
# Username бота для Telegram Login Widget (без @)
ADMIN_WEB_TELEGRAM_BOT_USERNAME=
# Альтернативный вход по логину/паролю
ADMIN_WEB_PASSWORD_AUTH_ENABLED=true
# Минимальная длина пароля
ADMIN_WEB_PASSWORD_MIN_LENGTH=10
# Rate limit (password login)
ADMIN_WEB_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_WEB_PASSWORD_RATE_LIMIT_MAX_ATTEMPTS=10
# Блокировка аккаунта после N подряд неуспешных попыток
ADMIN_WEB_PASSWORD_LOCKOUT_THRESHOLD=5
ADMIN_WEB_PASSWORD_LOCKOUT_MINUTES=15

# =============================================
# Telegram API network settings
# =============================================
# Профиль 1 (умеренно медленная сеть) — активный по умолчанию:
TELEGRAM_HTTP_MAX_RETRIES=4
TELEGRAM_HTTP_RETRY_BACKOFF_SECONDS=2
# Таймаут установки TCP/TLS-соединения для sendMessage (сек.)
TELEGRAM_SEND_MSG_CONNECT_TIMEOUT_SECONDS=5
# Таймаут ожидания ответа Telegram после отправки sendMessage (сек.)
TELEGRAM_SEND_MSG_READ_TIMEOUT_SECONDS=30
# Таймаут установки TCP/TLS-соединения для sendDocument (сек.)
TELEGRAM_SEND_DOC_CONNECT_TIMEOUT_SECONDS=20
# Таймаут чтения ответа Telegram при загрузке файла sendDocument (сек.)
TELEGRAM_SEND_DOC_READ_TIMEOUT_SECONDS=300

# Профиль 2 (очень медленная/нестабильная сеть) — раскомментируйте при необходимости:
# TELEGRAM_HTTP_MAX_RETRIES=6
# TELEGRAM_HTTP_RETRY_BACKOFF_SECONDS=2
# Таймаут установки TCP/TLS-соединения для sendMessage (сек.)
# TELEGRAM_SEND_MSG_CONNECT_TIMEOUT_SECONDS=10
# Таймаут ожидания ответа Telegram после отправки sendMessage (сек.)
# TELEGRAM_SEND_MSG_READ_TIMEOUT_SECONDS=60
# Таймаут установки TCP/TLS-соединения для sendDocument (сек.)
# TELEGRAM_SEND_DOC_CONNECT_TIMEOUT_SECONDS=30
# Таймаут чтения ответа Telegram при загрузке файла sendDocument (сек.)
# TELEGRAM_SEND_DOC_READ_TIMEOUT_SECONDS=600

# =============================================
# Telethon (for chat members sync)
# =============================================
# Get API credentials from https://my.telegram.org
TELETHON_API_ID=12345678
TELETHON_API_HASH=your_api_hash_here

# =============================================
# Chat members sync
# =============================================
SYNC_CHAT_ID=-1001395495746
SYNC_INTERVAL_HOURS=6
TELETHON_SESSION_NAME=chat_sync_session

# =============================================
# FIAS address validation (DaData)
# =============================================
# Get your API key at https://dadata.ru/profile/
DADATA_API_KEY=your_dadata_api_key_here
# Optional: override the API base URL
# DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs
# Optional: choose the FIAS provider (default: dadata)
# FIAS_PROVIDER=dadata

# =============================================
# AI / RAG (опционально)
# =============================================
# AI_RAG_ENABLED=1
# AI_RAG_CHUNK_SIZE=1000
# AI_RAG_CHUNK_OVERLAP=150
# AI_RAG_TOP_K=8
# AI_RAG_MAX_CONTEXT_CHARS=14000
# AI_RAG_SUMMARY_ENABLED=1
# AI_RAG_PREFILTER_TOP_DOCS=4
# Не учитывать source_type=certification в квоте AI_RAG_PREFILTER_TOP_DOCS.
# Сертификационные документы остаются в prefilter-выдаче, но не занимают квоту обычных документов.
# AI_RAG_PREFILTER_EXCLUDE_CERTIFICATION_FROM_COUN  T=1
# AI_RAG_PROMPT_SUMMARY_DOCS=1
# Исключать summary сертификационных вопросов из prompt-блока joined_summaries.
# Влияет только на системный RAG prompt, не влияет на retrieval/ranking.
# AI_RAG_PROMPT_SUMMARIES_EXCLUDE_CERTIFICATION=1

# Векторный retrieval (remote-first + local fallback)
# AI_RAG_VECTOR_ENABLED=0
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# Адрес удалённого Qdrant (если задан, используется в приоритете).
# AI_RAG_VECTOR_REMOTE_URL=
# API ключ удалённого Qdrant (опционально).
# AI_RAG_VECTOR_REMOTE_API_KEY=
# Таймаут запросов к удалённому Qdrant (секунды).
# AI_RAG_VECTOR_REMOTE_TIMEOUT_SECONDS=5
# Порог последовательных ошибок remote до переключения на local.
# AI_RAG_VECTOR_REMOTE_FAILURE_THRESHOLD=3
# Время cooldown remote после failover (секунды).
# AI_RAG_VECTOR_REMOTE_COOLDOWN_SECONDS=120
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# Отдельная коллекция summary-документов для ускорения prefilter первого запроса.
# AI_RAG_SUMMARY_VECTOR_COLLECTION=rag_document_summaries_v1
# Отдельная коллекция для скрипта remote->local sync (по умолчанию наследует AI_RAG_VECTOR_COLLECTION).
# AI_RAG_VECTOR_SYNC_COLLECTION=rag_chunks_v1
# Мягкий буст score для сертификационных документов при совпадении категории запроса.
# AI_RAG_CERTIFICATION_CATEGORY_BOOST=0.35
# Штраф score для неактивных/устаревших сертификационных документов.
# AI_RAG_CERTIFICATION_STALE_PENALTY=0.20
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_TOP_K=12
# AI_RAG_SUMMARY_VECTOR_TOP_K=0
# AI_RAG_VECTOR_PREFETCH_K=40
# AI_RAG_VECTOR_EMBEDDING_MODEL=BAAI/bge-m3
# AI_RAG_VECTOR_DEVICE=auto
# AI_RAG_VECTOR_EMBEDDING_FP16=0
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=8
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=6000
# Директория кэша sentence-transformers (постоянный volume для офлайн-старта).
# AI_RAG_VECTOR_EMBEDDING_CACHE_DIR=./data/models/sentence_transformers
# Запускать embedding-модель только из локального кэша (без сети/Hugging Face).
# AI_RAG_VECTOR_EMBEDDING_OFFLINE=0
# При недоступности embedding/vector завершать старт процесса с ошибкой.
# AI_RAG_VECTOR_EMBEDDING_FAIL_FAST=0
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.45
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.55

# =============================================
# Профиль lexical BM25 для русского языка (готовый пресет)
# =============================================
# Включает BM25-ранжирование для чанков и summary-prefilter
# + RU-нормализацию токенов (лемматизация/стемминг).
# Рекомендуется для русскоязычной базы знаний.
# AI_RAG_LEXICAL_SCORER=bm25
# AI_RAG_BM25_K1=1.5
# AI_RAG_BM25_B=0.75
# AI_RAG_RU_NORMALIZATION_ENABLED=1
# AI_RAG_RU_NORMALIZATION_MODE=lemma_then_stem

# =============================================
# Query preprocessing для lexical retrieval
# =============================================
# Фильтрация русских стоп-слов из запроса перед lexical scoring.
# AI_RAG_STOPWORDS_ENABLED=1
# Снятие шаблонных вопросительных паттернов («что такое X» → «X»).
# AI_RAG_QUERY_PATTERN_STRIP_ENABLED=1
# Порог DF для IDF dampening query-токенов в prefilter (0..1).
# Токены, встречающиеся в более чем данной доле summary, подавляются.
# AI_RAG_PREFILTER_IDF_DAMPEN_RATIO=0.8
# Множитель для dampened-токенов (0..1, меньше = сильнее подавление).
# AI_RAG_PREFILTER_IDF_DAMPEN_FACTOR=0.1

# =============================================
# HyDE (Hypothetical Document Embeddings)
# =============================================
# Включить генерацию гипотетического документа LLM для vector search.
# LLM генерирует короткий ответ-гипотезу, его эмбеддинг используется
# для vector search вместо эмбеддинга исходного вопроса.
# AI_RAG_HYDE_ENABLED=0
# Максимальная длина гипотетического документа (символы).
# AI_RAG_HYDE_MAX_CHARS=500
# TTL кэша HyDE-текстов (секунды).
# AI_RAG_HYDE_CACHE_TTL_SECONDS=300
# Дополнять BM25 lexical scoring уникальными токенами из HyDE-текста.
# При выключении HyDE используется только для vector search.
# AI_RAG_HYDE_LEXICAL_ENABLED=1

# =============================================
# Профили vector RAG (готовые пресеты)
# =============================================

# Профиль A: macOS (сбалансированный, BGE-M3)
# AI_RAG_VECTOR_ENABLED=1
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# AI_RAG_VECTOR_REMOTE_URL=
# AI_RAG_VECTOR_REMOTE_API_KEY=
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# AI_RAG_SUMMARY_VECTOR_COLLECTION=rag_document_summaries_v1
# AI_RAG_VECTOR_SYNC_COLLECTION=rag_chunks_v1
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_EMBEDDING_MODEL=BAAI/bge-m3
# AI_RAG_VECTOR_EMBEDDING_FP16=0
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=6
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=5000
# AI_RAG_VECTOR_TOP_K=14
# AI_RAG_SUMMARY_VECTOR_TOP_K=0
# AI_RAG_VECTOR_PREFETCH_K=42
# AI_RAG_TOP_K=8
# AI_RAG_MAX_CONTEXT_CHARS=14000
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.40
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.60

# Профиль B: Windows (i5-3550 + NVIDIA T400, стабильный)
# Рекомендация: использовать более лёгкую multilingual модель.
# AI_RAG_VECTOR_ENABLED=1
# AI_RAG_HYBRID_ENABLED=1
# AI_RAG_VECTOR_LOCAL_MODE=1
# AI_RAG_VECTOR_REMOTE_URL=
# AI_RAG_VECTOR_REMOTE_API_KEY=
# AI_RAG_VECTOR_DB_PATH=./data/qdrant
# AI_RAG_VECTOR_COLLECTION=rag_chunks_v1
# AI_RAG_SUMMARY_VECTOR_COLLECTION=rag_document_summaries_v1
# AI_RAG_VECTOR_SYNC_COLLECTION=rag_chunks_v1
# AI_RAG_VECTOR_DISTANCE=cosine
# AI_RAG_VECTOR_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# AI_RAG_VECTOR_DEVICE=auto
# AI_RAG_VECTOR_EMBEDDING_FP16=1
# AI_RAG_VECTOR_EMBEDDING_BATCH_SIZE=2
# AI_RAG_VECTOR_EMBEDDING_MAX_CHARS=3500
# AI_RAG_VECTOR_TOP_K=10
# AI_RAG_SUMMARY_VECTOR_TOP_K=0
# AI_RAG_VECTOR_PREFETCH_K=24
# AI_RAG_TOP_K=7
# AI_RAG_MAX_CONTEXT_CHARS=12000
# AI_RAG_VECTOR_LEXICAL_WEIGHT=0.55
# AI_RAG_VECTOR_SEMANTIC_WEIGHT=0.45